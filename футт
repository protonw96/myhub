import pygame
import sys
import math
import random

# Инициализация Pygame
pygame.init()

# Размеры экрана
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Я - Вратарь! Симулятор сейвов")
clock = pygame.time.Clock()

# Размеры объектов
PLAYER_SIZE = 60  # Вратаря сделали чуть больше, чтобы было удобнее ловить
BALL_RADIUS = 18

# Позиция ворот (сверху экрана)
GOAL_X_LEFT = 150
GOAL_X_RIGHT = 650
GOAL_Y = 90

# Цвета
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
RED = (255, 50, 50)
GREEN = (50, 255, 50)

# --- БЕЗОПАСНАЯ ЗАГРУЗКА ТЕКСТУР ---
def load_image(filename, scale_to=None, has_alpha=True):
    try:
        img = pygame.image.load(filename)
        img = img.convert_alpha() if has_alpha else img.convert()
        if scale_to:
            img = pygame.transform.scale(img, scale_to)
        return img
    except pygame.error:
        # Если текстуры нет рядом — генерируем цветной прямоугольник/круг
        size = scale_to if scale_to else (50, 50)
        fallback = pygame.Surface(size, pygame.SRCALPHA)
        if "footbal" in filename:
            pygame.draw.circle(fallback, WHITE, (size[0]//2, size[1]//2), size[0]//2)
            pygame.draw.circle(fallback, BLACK, (size[0]//2, size[1]//2), size[0]//2, 2)
        elif "footballer" in filename:
            fallback.fill((220, 20, 60))  # Красный свитер вратаря по умолчанию
        else:
            fallback.fill((34, 139, 34))  # Зеленая трава
        return fallback

# Загрузка твоих файлов
field_img = load_image("pole.png", (WIDTH, HEIGHT), has_alpha=False)
ball_img = load_image("footbal.png", (BALL_RADIUS * 2, BALL_RADIUS * 2))
gk_img = load_image("footballer1.png", (PLAYER_SIZE, PLAYER_SIZE)) 

# Повернем вратаря лицом к полю (вниз)
gk_img = pygame.transform.flip(gk_img, False, True)


class Goalkeeper:
    def __init__(self, y):
        self.x = WIDTH // 2
        self.y = y
        self.size = PLAYER_SIZE

    def update(self):
        # Вратарь управляется движениями МЫШКИ по горизонтали
        mouse_x, _ = pygame.mouse.get_pos()
        self.x = mouse_x

        # Ограничиваем движение вратаря, чтобы он не уходил за штанги слишком далеко
        self.x = max(GOAL_X_LEFT - 10, min(GOAL_X_RIGHT + 10, self.x))

    def draw(self, surface):
        surface.blit(gk_img, (int(self.x - self.size/2), int(self.y - self.size/2)))


class Ball:
    def __init__(self):
        self.reset()

    def reset(self):
        # Мяч появляется внизу в случайной точке атаки
        self.x = random.randint(200, 600)
        self.y = HEIGHT - 50
        self.vx = 0
        self.vy = 0
        self.radius = BALL_RADIUS
        
        # Таймер перед ударом ИИ (чтобы игрок успел среагировать)
        self.shoot_delay = 45  # Примерно 0.7 секунды подготовки
        self.has_shot = False

    def update(self):
        if not self.has_shot:
            self.shoot_delay -= 1
            if self.shoot_delay <= 0:
                # ИИ делает удар! Направляет мяч строго в створ ворот
                target_x = random.randint(GOAL_X_LEFT + 20, GOAL_X_RIGHT - 20)
                target_y = GOAL_Y
                
                # Расчет вектора скорости
                dx = target_x - self.x
                dy = target_y - self.y
                distance = math.hypot(dx, dy)
                
                # Случайная скорость удара (от слабой до очень быстрой)
                speed = random.uniform(11, 16)
                
                self.vx = (dx / distance) * speed
                self.vy = (dy / distance) * speed
                self.has_shot = True
        else:
            # Мяч летит
            self.x += self.vx
            self.y += self.vy

            # Отскок от левой/правой кромки поля, если удар косой
            if self.x - self.radius <= 0 or self.x + self.radius >= WIDTH:
                self.vx *= -1

    def draw(self, surface):
        # Если нападающий целится, под мячом можно нарисовать легкую тень (необязательно)
        surface.blit(ball_img, (int(self.x - self.radius), int(self.y - self.radius)))


def check_save(gk, ball):
    # Проверка столкновения перчаток/тела вратаря с мячом
    dx = ball.x - gk.x
    dy = ball.y - gk.y
    distance = math.hypot(dx, dy)
    min_dist = (gk.size / 2) + ball.radius

    if distance < min_dist and ball.vy < 0:
        return True
    return False


def main():
    # Скрываем системный курсор мыши, так как перчатки вратаря — это наш новый курсор
    pygame.mouse.set_visible(False)

    gk = Goalkeeper(GOAL_Y + 20)
    ball = Ball()

    saves_count = 0
    lives = 3
    
    game_state = "PLAYING" # Может быть "PLAYING" или "GAMEOVER"
    
    message = ""
    message_timer = 0
    message_color = GREEN

    font = pygame.font.SysFont("Arial", 36, bold=True)
    ui_font = pygame.font.SysFont("Arial", 24, bold=True)

    running = True
    while running:
        clock.tick(60)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_r and game_state == "GAMEOVER":
                    # Перезапуск игры по нажатию на R
                    saves_count = 0
                    lives = 3
                    game_state = "PLAYING"
                    ball.reset()

        if game_state == "PLAYING":
            # Логика игры
            gk.update()
            ball.update()

            # 1. Проверяем СЕЙВ
            if check_save(gk, ball):
                saves_count += 1
                message = "ОТБИТО! +1 Сейв"
                message_color = GREEN
                message_timer = 40
                ball.reset()

            # 2. Проверяем ГОЛ (мяч улетел выше линии ворот)
            elif ball.y < GOAL_Y:
                if GOAL_X_LEFT <= ball.x <= GOAL_X_RIGHT:
                    # Пропустили гол
                    lives -= 1
                    message = "ПРОПУСТИЛ ГОЛ!"
                    message_color = RED
                    message_timer = 50
                    if lives <= 0:
                        game_state = "GAMEOVER"
                else:
                    # Мяч пролетел мимо створа (аут)
                    message = "МИМО ВОРОТ!"
                    message_color = WHITE
                    message_timer = 40
                
                if game_state != "GAMEOVER":
                    ball.reset()

        # --- ОТРИСОВКА ---
        # Рисуем поле (поле pole.png)
        screen.blit(field_img, (0, 0))

        # Отрисовка сетки и штанг ворот сверху поля
        pygame.draw.rect(screen, (30, 50, 30), (GOAL_X_LEFT, GOAL_Y - 30, GOAL_X_RIGHT - GOAL_X_LEFT, 30)) # сетка
        pygame.draw.line(screen, WHITE, (GOAL_X_LEFT, GOAL_Y), (GOAL_X_RIGHT, GOAL_Y), 6) # линия
        pygame.draw.circle(screen, WHITE, (GOAL_X_LEFT, GOAL_Y), 6)  # левая штанга
        pygame.draw.circle(screen, WHITE, (GOAL_X_RIGHT, GOAL_Y), 6) # правая штанга

        # Рисуем вратаря и мяч
        if game_state == "PLAYING":
            gk.draw(screen)
            ball.draw(screen)

        # Интерфейс (Сейвы и Жизни)
        saves_text = ui_font.render(f"Сейвы: {saves_count}", True, WHITE)
        lives_text = ui_font.render(f"Жизни: {'♥ ' * lives}", True, RED)
        screen.blit(saves_text, (20, 20))
        screen.blit(lives_text, (WIDTH - 150, 20))

        # Эффекты надписей (СЕЙВ / ГОЛ)
        if message_timer > 0 and game_state == "PLAYING":
            msg_surf = font.render(message, True, message_color)
            msg_rect = msg_surf.get_rect(center=(WIDTH // 2, HEIGHT // 2 - 50))
            screen.blit(msg_surf, msg_rect)
            message_timer -= 1

        # Экран Конца Игры
        if game_state == "GAMEOVER":
            pygame.mouse.set_visible(True) # Возвращаем курсор для удобства
            go_text = font.render("ИГРА ОКОНЧЕНА", True, RED)
            res_text = ui_font.render(f"Вы отбили столько мячей: {saves_count}", True, WHITE)
            hint_text = ui_font.render("Нажмите [R] для перезапуска", True, GREEN)
            
            screen.blit(go_text, (WIDTH//2 - go_text.get_width()//2, HEIGHT//2 - 60))
            screen.blit(res_text, (WIDTH//2 - res_text.get_width()//2, HEIGHT//2))
            screen.blit(hint_text, (WIDTH//2 - hint_text.get_width()//2, HEIGHT//2 + 50))

        pygame.display.flip()

    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
