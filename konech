def show_go_screen(screen, bg_img, score):
    screen.blit(bg_img, (0, 0))
    # Рисуем надпись Game Over
    draw_text(screen, "GAME OVER", 64, WIDTH // 2, HEIGHT / 4)
    # Рисуем количество набранных очков
    draw_text(screen, f"SCORE: {score}", 36, WIDTH // 2, HEIGHT / 2)
    # Инструкция по перезапуску
    draw_text(screen, "Press any key to play again", 22, WIDTH // 2, HEIGHT * 0.75)
    
    pygame.display.flip()
    
    # Ждем нажатия клавиши
    waiting = True
    while waiting:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()
            if event.type == pygame.KEYDOWN:
                waiting = False
